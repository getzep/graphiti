OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# Endpoint split (Phase C — Slice 3)
# Use SEPARATE env vars for LLM and embedder if they route to different services.
# Example: LLM via OpenRouter, embeddings via local Ollama.
# ─────────────────────────────────────────────────────────────────────────────

# LLM (chat-completions) endpoint — preferred over OPENAI_BASE_URL for LLM routing
# Priority: OM_COMPRESSOR_LLM_BASE_URL > LLM_BASE_URL > OPENAI_BASE_URL > https://api.openai.com/v1
LLM_BASE_URL=
# Optional per-script override (om_compressor only)
OM_COMPRESSOR_LLM_BASE_URL=

# Embedder endpoint — use this to route embeddings separately from LLM
# Priority: EMBEDDER_BASE_URL > OPENAI_BASE_URL > http://localhost:11434/v1
EMBEDDER_BASE_URL=
EMBEDDER_API_KEY=

# Legacy: shared OpenAI-compatible base URL (used for both LLM + embedding if
# the above are not set). Prefer LLM_BASE_URL + EMBEDDER_BASE_URL instead.
OPENAI_BASE_URL=

# Set to 1 to allow local (loopback/private) LLM endpoints in dev (e.g. Ollama)
OM_ALLOW_LOCAL_LLM=

# ─────────────────────────────────────────────────────────────────────────────
# Neo4j database connection
# ─────────────────────────────────────────────────────────────────────────────
NEO4J_URI=
NEO4J_PORT=
NEO4J_USER=
NEO4J_PASSWORD=

# FalkorDB database connection 
FALKORDB_URI=
FALKORDB_PORT=
FALKORDB_USER=
FALKORDB_PASSWORD=

USE_PARALLEL_RUNTIME=
SEMAPHORE_LIMIT=
GITHUB_SHA=
MAX_REFLEXION_ITERATIONS=
ANTHROPIC_API_KEY=