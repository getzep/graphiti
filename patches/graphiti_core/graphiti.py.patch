+def _phase3c_normalize_text(value: str) -> str:
+    return re.sub(r'\s+', ' ', value or '').strip()
+
+
+def _phase3c_source_chunk_key(source_description: str) -> str:
+    if not source_description:
+        return ''
+    match = re.search(r'session chunk:\s*([^\(]+)', source_description)
+    if match:
+        return match.group(1).strip()
+    return ''
+
+
+def _phase3c_is_meta_or_tautological(text: str) -> bool:
+    normalized = _phase3c_normalize_text(text)
+    if not normalized:
+        return True
+    if len(normalized.split()) < 4:
+        return True
+    return any(pattern.search(normalized) for pattern in PHASE3C_META_PATTERNS)
+
+
+def _phase3c_evidence_supported(evidence_span: str, episode_text: str) -> bool:
+    evidence = _phase3c_normalize_text(evidence_span).strip('"\'`')
+    if len(evidence) < 8:
+        return False
+
+    haystack = (episode_text or '').lower()
+    if not haystack:
+        return False
+
+    if evidence.lower() in haystack:
+        return True
+
+    evidence_tokens = [t for t in re.findall(r'[a-z0-9]+', evidence.lower()) if len(t) >= 3]
+    if not evidence_tokens:
+        return False
+
+    haystack_tokens = set(re.findall(r'[a-z0-9]+', haystack))
+    overlap = sum(1 for token in evidence_tokens if token in haystack_tokens)
+    return overlap / max(1, len(evidence_tokens)) >= 0.6
+
+
+def _phase3c_candidate_text_from_node(node: EntityNode) -> str:
+    parts: list[str] = []
+    if node.name:
+        parts.append(str(node.name))
+    if node.summary:
+        parts.append(str(node.summary))
+    if isinstance(node.attributes, dict):
+        for key in PHASE3C_REQUIRED_FIELDS:
+            value = str(node.attributes.get(key, '')).strip()
+            if value:
+                parts.append(f'{key}: {value}')
+    return ' | '.join(_phase3c_normalize_text(p) for p in parts if _phase3c_normalize_text(p))
+
