+    def _phase3c_drop_log_path(self) -> Path:
+        raw = os.environ.get('GRAPHITI_DROPPED_CANDIDATES_LOG', '').strip()
+        if raw:
+            return Path(raw).expanduser().resolve()
+        return PHASE3C_DROPPED_LOG_DEFAULT
+
+    def _phase3c_log_drop(
+        self,
+        *,
+        lane: str,
+        episode: EpisodicNode,
+        candidate_kind: str,
+        candidate_content: str,
+        reject_reasons: list[str],
+        source_node_uuid: str = '',
+        target_node_uuid: str = '',
+        candidate_meta: dict[str, Any] | None = None,
+    ) -> None:
+        if not reject_reasons:
+            return
+
+        payload: dict[str, Any] = {
+            'timestamp': datetime.now(timezone.utc).isoformat(),
+            'lane': lane,
+            'candidate_kind': candidate_kind,
+            'candidate_content': _phase3c_normalize_text(candidate_content),
+            'reject_reasons': sorted(set(reject_reasons)),
+            'episode_uuid': str(episode.uuid),
+            'episode_name': str(episode.name),
+            'source_description': str(episode.source_description or ''),
+            'chunk_key': _phase3c_source_chunk_key(str(episode.source_description or '')),
+            'source_node_uuid': source_node_uuid,
+            'target_node_uuid': target_node_uuid,
+        }
+        if candidate_meta:
+            payload['candidate_meta'] = candidate_meta
+
+        path = self._phase3c_drop_log_path()
+        try:
+            path.parent.mkdir(parents=True, exist_ok=True)
+            with path.open('a', encoding='utf-8') as handle:
+                handle.write(json.dumps(payload, ensure_ascii=False) + '\n')
+        except Exception as exc:
+            logger.warning('Failed to write Phase 3C dropped-candidate log: %s', exc)
+
+    def _phase3c_filter_extracted_nodes(
+        self,
+        *,
+        group_id: str,
+        episode: EpisodicNode,
+        extracted_nodes: list[EntityNode],
+    ) -> list[EntityNode]:
+        """Drop obvious meta/tautological node candidates pre-resolution."""
+        if group_id not in PHASE3C_FILTER_LANES:
+            return extracted_nodes
+
+        kept: list[EntityNode] = []
+        for node in extracted_nodes:
+            candidate_text = _phase3c_candidate_text_from_node(node)
+            reasons: list[str] = []
+            if _phase3c_is_meta_or_tautological(candidate_text):
+                reasons.append('meta_or_tautological')
+
+            if reasons:
+                self._phase3c_log_drop(
+                    lane=group_id,
+                    episode=episode,
+                    candidate_kind='entity_pre_resolve',
+                    candidate_content=candidate_text,
+                    reject_reasons=reasons,
+                    candidate_meta={
+                        'labels': list(node.labels or []),
+                        'name': str(node.name),
+                    },
+                )
+                continue
+
+            kept.append(node)
+
+        return kept
+
+    def _phase3c_filter_graph_write_candidates(
+        self,
+        *,
+        group_id: str,
+        episode: EpisodicNode,
+        nodes: list[EntityNode],
+        entity_edges: list[EntityEdge],
+        invalidated_edges: list[EntityEdge],
+    ) -> tuple[list[EntityNode], list[EntityEdge], list[EntityEdge]]:
+        """Hard gate craft/evidence quality before graph write (3 lanes only)."""
+        if group_id not in PHASE3C_FILTER_LANES:
+            return nodes, entity_edges, invalidated_edges
+
+        anchor_types = PHASE3C_ANCHOR_ENTITY_TYPES.get(group_id, set())
+        kept_nodes: list[EntityNode] = []
+        dropped_node_ids: set[str] = set()
+
+        for node in nodes:
+            labels = {label for label in (node.labels or []) if label != 'Entity'}
+            primary_label = next(iter(labels), '')
+            candidate_text = _phase3c_candidate_text_from_node(node)
+            reasons: list[str] = []
+
+            if primary_label not in anchor_types:
+                attrs = node.attributes if isinstance(node.attributes, dict) else {}
+                for field_name in PHASE3C_REQUIRED_FIELDS:
+                    if not _phase3c_normalize_text(str(attrs.get(field_name, ''))):
+                        reasons.append(f'missing_{field_name}')
+
+                evidence_span = str(attrs.get('evidence_span', ''))
+                if not _phase3c_evidence_supported(evidence_span, episode.content or ''):
+                    reasons.append('weak_or_unverifiable_evidence_span')
+
+                if _phase3c_is_meta_or_tautological(candidate_text):
+                    reasons.append('meta_or_tautological')
+
+            if reasons:
+                dropped_node_ids.add(str(node.uuid))
+                self._phase3c_log_drop(
+                    lane=group_id,
+                    episode=episode,
+                    candidate_kind='entity',
+                    candidate_content=candidate_text,
+                    reject_reasons=reasons,
+                    source_node_uuid=str(node.uuid),
+                    candidate_meta={
+                        'labels': sorted(labels),
+                        'name': str(node.name),
+                        'summary': str(node.summary),
+                        'attributes': node.attributes if isinstance(node.attributes, dict) else {},
+                    },
+                )
+                continue
+
+            kept_nodes.append(node)
+
+        def _filter_edges(edges: list[EntityEdge], *, candidate_kind: str) -> list[EntityEdge]:
+            kept_edges: list[EntityEdge] = []
+            for edge in edges:
+                fact = _phase3c_normalize_text(str(edge.fact or ''))
+                reasons: list[str] = []
+
+                if str(edge.source_node_uuid) in dropped_node_ids or str(edge.target_node_uuid) in dropped_node_ids:
+                    reasons.append('references_dropped_node')
+                if not fact:
+                    reasons.append('missing_fact')
+                elif _phase3c_is_meta_or_tautological(fact):
+                    reasons.append('meta_or_tautological')
+
+                if reasons:
+                    self._phase3c_log_drop(
+                        lane=group_id,
+                        episode=episode,
+                        candidate_kind=candidate_kind,
+                        candidate_content=fact,
+                        reject_reasons=reasons,
+                        source_node_uuid=str(edge.source_node_uuid),
+                        target_node_uuid=str(edge.target_node_uuid),
+                        candidate_meta={
+                            'edge_name': str(edge.name),
+                        },
+                    )
+                    continue
+
+                kept_edges.append(edge)
+
+            return kept_edges
+
+        kept_entity_edges = _filter_edges(entity_edges, candidate_kind='edge')
+        kept_invalidated_edges = _filter_edges(invalidated_edges, candidate_kind='invalidated_edge')
+
+        return kept_nodes, kept_entity_edges, kept_invalidated_edges
+
