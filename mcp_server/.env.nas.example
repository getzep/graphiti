# NAS deployment example for graphiti-mcp.
# This matches the current REST-side style:
# - glm-5
# - OpenAI-compatible endpoint
# - external Neo4j on the NAS

# Expose MCP on a port different from graphiti-api (which is already using 8010)
MCP_PORT=8011

# Shared Neo4j connection
NEO4J_URI=bolt://192.168.123.104:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_password
NEO4J_DATABASE=neo4j

# Default MCP namespace.
# Use a dedicated group_id if you want MCP memories isolated from graphiti-api.
GRAPHITI_GROUP_ID=nas_mcp

# Allow MCP clients to reach the NAS host directly.
# This fixes "421 Invalid Host header" for streamable HTTP access.
MCP_ALLOWED_HOSTS=localhost:*,127.0.0.1:*,192.168.123.104:*

# Concurrency tuning
SEMAPHORE_LIMIT=10

# LLM configuration
# Switch providers/endpoints here without editing the compose YAML.
# For the validated GLM-5 OpenAI-compatible path, use the paas/v4 endpoint.
LLM_MODEL=glm-5
OPENAI_API_KEY=your_api_key
OPENAI_API_URL=https://open.bigmodel.cn/api/paas/v4/

# Embedder configuration
# Recommended validated setup:
# keep LLM on glm-5, and point the embedder to the Ollama-hosted qwen3 embedding model.
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=qwen3-embedding:0.6b
EMBEDDER_DIMENSIONS=1024
EMBEDDER_OPENAI_API_KEY=ollama
EMBEDDER_OPENAI_API_URL=http://192.168.123.74:11434/v1
